---
import Header from "../components/Header.astro";
import BlogCard from "../components/BlogCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { blogs, projects } from "../data/homeContent";

import { Icon } from "astro-icon/components";

const blogGroups = blogs.reduce((groups, blog) => {
  const existingGroup = groups.find((group) => group.year === blog.year);

  if (existingGroup) {
    existingGroup.entries.push(blog);
  } else {
    groups.push({ year: blog.year, entries: [blog] });
  }

  return groups;
}, [] as { year: string; entries: typeof blogs }[]);
---

<BaseLayout>
  <main class="mainContainer">
    <Header class="header"></Header>

    <section class="homeShell">
      <div class="sectionNavContainer">
        <div class="sectionNav" role="tablist" aria-label="Content sections">
          <button
            type="button"
            class="sectionNavButton isActive"
            data-section-trigger
            data-section="blogs"
            role="tab"
            aria-selected="true"
            aria-controls="panel-blogs"
            id="tab-blogs"
            tabindex="0"
          >
            Blogs
          </button>
          <button
            type="button"
            class="sectionNavButton"
            data-section-trigger
            data-section="projects"
            role="tab"
            aria-selected="false"
            aria-controls="panel-projects"
            id="tab-projects"
            tabindex="-1"
          >
            Projects
          </button>
        </div>
      </div>

      <div class="sectionPanels">
        <section
          class="blogCardContainer sectionPanel"
          data-section-panel="blogs"
          id="panel-blogs"
          role="tabpanel"
          aria-labelledby="tab-blogs"
        >
          {blogGroups.map((group, groupIndex) => (
            <>
              {groupIndex > 0 && <h2 class="yearSeparator">{group.year}</h2>}
              {group.entries.map((blog) => (
                <BlogCard
                  class="container"
                  title={blog.title}
                  meta={blog.publishDate}
                  summary={blog.summary}
                  primaryHref={blog.href}
                  primaryLabel="Read article"
                  primaryAria={blog.ariaLabel}
                  linkEntireCard={true}
                />
              ))}
            </>
          ))}
        </section>

        <section
          class="blogCardContainer sectionPanel"
          data-section-panel="projects"
          id="panel-projects"
          role="tabpanel"
          aria-labelledby="tab-projects"
          hidden
        >
          {projects.map((project) => (
            <BlogCard
              class="container"
              title={project.title}
              meta={project.releaseDate}
              summary={project.summary}
              secondaryHref={project.repoUrl}
              secondaryLabel="View code"
              secondaryAria={`View ${project.title} on GitHub`}
              installCommand={project.installCommand}
            />
          ))}
        </section>
      </div>
    </section>

    <footer class="container footer">
      <ul class="socialsList">
        <li>
          <a href="https://github.com/SamBWagner" rel="nofollow" target="_blank" title="GitHub profile" aria-label="GitHub profile">
            <Icon name="simple-line-icons:social-github" class="gitHub" />
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/sam-b-wagner" rel="nofollow" target="_blank" title="LinkedIn profile" aria-label="LinkedIn profile">
            <Icon name="simple-line-icons:social-linkedin" class="linkedIn" />
          </a>
        </li>
        <li>
          <a href="https://www.ssw.com.au/people/sam-wagner/" rel="nofollow" target="_blank" title="SSW People Profile" aria-label="SSW People Profile">
            <Icon name="simple-line-icons:people" class="ssw-people" />
          </a>
        </li>
        <li>
          <a href="https://buymeacoffee.com/sambwagner" rel="nofollow" target="_blank" title="Buy Me A Coffee" aria-label="Buy Me A Coffee">
            <Icon name="simple-line-icons:cup" class="buyMeACoffee" />
          </a>
        </li>
        <li>
          <a href="/rss.xml" target="_blank" title="RSS feed" aria-label="RSS feed">
            <Icon name="simple-line-icons:feed" class="rss" />
          </a>
        </li>
      </ul>
    </footer>
  </main>
</BaseLayout>

<script is:inline>
  const validSections = ["blogs", "projects"];
  const tabButtons = Array.from(document.querySelectorAll("[data-section-trigger]"));
  const panels = Array.from(document.querySelectorAll("[data-section-panel]"));

  function setActiveSection(section, pushHash = false) {
    const nextSection = validSections.includes(section) ? section : "blogs";

    tabButtons.forEach((button) => {
      const isActive = button.dataset.section === nextSection;
      button.classList.toggle("isActive", isActive);
      button.setAttribute("aria-selected", isActive ? "true" : "false");
      button.setAttribute("tabindex", isActive ? "0" : "-1");
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.sectionPanel !== nextSection;
    });

    if (pushHash) {
      window.history.replaceState(null, "", `#${nextSection}`);
    }
  }

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActiveSection(button.dataset.section, true);
    });
  });

  document.addEventListener("click", async (event) => {
    const button = event.target instanceof Element
      ? event.target.closest("[data-copy-text]")
      : null;

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const copyText = button.dataset.copyText;

    if (!copyText) {
      return;
    }

    try {
      await navigator.clipboard.writeText(copyText);
      const originalAriaLabel = button.getAttribute("aria-label");
      button.dataset.copyState = "copied";
      button.setAttribute("aria-label", "Copied");
      button.setAttribute("title", "Copied");
      window.setTimeout(() => {
        delete button.dataset.copyState;
        button.setAttribute("aria-label", originalAriaLabel ?? "Copy");
        button.setAttribute("title", "Copy install command");
      }, 1600);
    } catch {
      button.setAttribute("aria-label", "Copy failed");
      button.setAttribute("title", "Copy failed");
      window.setTimeout(() => {
        button.setAttribute("aria-label", `Copy command: ${copyText}`);
        button.setAttribute("title", "Copy install command");
      }, 1600);
    }
  });

  window.addEventListener("hashchange", () => {
    setActiveSection(window.location.hash.replace("#", ""));
  });

  setActiveSection(window.location.hash.replace("#", ""));
</script>

<style>
  .mainContainer {
    align-items: center;
    text-align: center;
    margin-top: auto;
    margin-bottom: auto;
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 5rem;
    margin-bottom: 3rem;
  }

  .homeShell {
    width: 100%;
    margin: 0 auto;
    padding: 0 1rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .sectionNavContainer {
    display: flex;
    justify-content: center;
  }

  .sectionNav {
    width: auto;
    max-width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .sectionNavButton {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--accent2);
    cursor: pointer;
    padding: 0.35rem 0.25rem;
    font-family: var(--neuton), serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .sectionNavButton:hover {
    color: var(--accent1-link-hover);
  }

  .sectionNavButton.isActive {
    color: var(--accent2);
    border-color: var(--accent2);
  }

  .sectionPanels {
    min-width: 0;
    width: 100%;
    overflow-x: clip;
  }

  .sectionPanel[hidden] {
    display: none;
  }

  .blogCardContainer {
    padding: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    justify-content: center;
    align-items: center;
  }

  .yearSeparator {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: none;
    margin: 0;
    font-family: var(--neuton), serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent2);
    letter-spacing: 2px;
  }

  .yearSeparator::before,
  .yearSeparator::after {
    content: "";
    flex: 1;
    border-top: 1px solid var(--accent2);
    opacity: 0.4;
  }

  .footer {
    padding-top: 2rem;
    padding-bottom: 1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
    max-width: var(--max-width);
    border-top-left-radius: var(--border-radius);
    border-top-right-radius: var(--border-radius);
  }

  .socialsList {
    display: flex;
    list-style-type: none;
    padding: 0;
    gap: 2rem;
  }

  .gitHub, .linkedIn, .rss, .ssw-people, .buyMeACoffee {
    font-size: 2rem;
    color: var(--accent1);
    transition: fill 0.3s ease, transform 0.3s ease;
  }

  .gitHub:hover, .linkedIn:hover, .rss:hover, .ssw-people:hover, .buyMeACoffee:hover {
    cursor: pointer;
    color: var(--accent1-link-hover);
    transform: scale(1.2);
  }

  @media (min-width: 900px) {
    .homeShell {
      display: block;
    }

    .sectionNavContainer {
      position: absolute;
      top: 0;
      left: max(1rem, calc(50% - (var(--max-width) / 2) - 8rem));
      width: 7rem;
      justify-content: flex-start;
      z-index: 2;
      pointer-events: none;
    }

    .sectionNav {
      position: sticky;
      top: 2rem;
      width: 7rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      align-self: start;
      max-width: none;
      justify-items: start;
      pointer-events: auto;
    }

    .sectionNavButton {
      text-align: left;
      font-size: 0.9rem;
      padding: 0.2rem 0;
    }

    .sectionPanels {
      width: 100%;
    }

    .blogCardContainer {
      padding-top: 0;
    }
  }
</style>
